{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "chat": {
      "description": "Chat-only assistant with online grounding; no local context",
      "mode": "primary",
      "prompt": "You are a chat-only assistant. Do not read local files or use local context. Only use online sources when needed. Be concise and conversational.",
      "permission": {
        "read": "deny",
        "edit": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "bash": "deny",
        "task": "deny",
        "lsp": "deny",
        "codesearch": "deny",
        "external_directory": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "skill": "deny",
        "websearch": "allow",
        "webfetch": "allow",
        "question": "allow"
      }
    }
  },
  "command": {
    "wiki-init": {
      "description": "Initializes this folder as an agent wiki",
      "agent": "build",
      "template": "Initialize this wiki using the AGENTS.md protocol."
    },
    "wiki-ingest": {
      "description": "Ingests and indexes all the documents in raw/",
      "agent": "build",
      "template": "Ingest everything currently in raw/. Index all documents found there."
    },
    "wiki-lint": {
      "description": "Lints the wiki and fixes found issues",
      "agent": "build",
      "template": "Lint the wiki and fix straightforward issues."
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    }
  },
}
